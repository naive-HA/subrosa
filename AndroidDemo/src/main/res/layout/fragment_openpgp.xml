<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.openpgp.OpenPgpFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/card_view_margin">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/activity_margin"
            android:text="@string/openpgp_desc" />

        <LinearLayout
            android:id="@+id/key_info_section"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_marginTop="@dimen/activity_margin"
            android:orientation="vertical"
            android:background="@color/armor_preview_background"
            android:padding="12dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/import_instructions"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="start"
                android:text="@string/openpgp_tap_to_paste"
                android:fontFamily="monospace"
                android:textSize="14sp"
                android:visibility="visible" />

            <LinearLayout
                android:id="@+id/key_details_container"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.35"
                        android:text="@string/openpgp_key_user_id"
                        android:textStyle="bold"
                        android:textSize="12sp" />
                    <TextView
                        android:id="@+id/key_info_user_id"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.65"
                        android:textSize="12sp"
                        android:ellipsize="end"
                        android:maxLines="2"
                        tools:text="Alice Doe &lt;alice@example.com&gt;" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.35"
                        android:text="@string/openpgp_key_algorithm"
                        android:textStyle="bold"
                        android:textSize="12sp" />
                    <TextView
                        android:id="@+id/key_info_algorithm"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.65"
                        android:textSize="12sp"
                        tools:text="EdDSA (Ed25519)" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.35"
                        android:text="@string/openpgp_key_created"
                        android:textStyle="bold"
                        android:textSize="12sp" />
                    <TextView
                        android:id="@+id/key_info_created"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.65"
                        android:textSize="12sp"
                        tools:text="2024-01-15" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.35"
                        android:text="@string/openpgp_key_expires"
                        android:textStyle="bold"
                        android:textSize="12sp" />
                    <TextView
                        android:id="@+id/key_info_expires"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.65"
                        android:textSize="12sp"
                        tools:text="2026-01-15" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/openpgp_key_fingerprint"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp" />
                <TextView
                    android:id="@+id/key_info_fingerprint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:textSize="11sp"
                    android:textIsSelectable="true"
                    android:layout_marginBottom="8dp"
                    tools:text="AABB CCDD EEFF 0011 2233  4455 6677 8899 AABB CCDD" />

            </LinearLayout>
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="@dimen/activity_margin">

            <Button
                android:id="@+id/btn_save"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/openpgp_btn_write" />

            <ProgressBar
                android:id="@+id/progress_save"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical|end"
                android:layout_marginEnd="16dp"
                android:visibility="gone" />

        </FrameLayout>

        <TextView
            android:id="@+id/write_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_horizontal"
            android:textSize="12sp"
            android:textColor="@android:color/darker_gray"
            android:fontFamily="monospace"
            android:text=""
            tools:text="Writing slot SIG…" />

        <View
            android:layout_width="match_parent"
            android:layout_height="5dp"
            android:layout_marginVertical="@dimen/activity_margin"
            android:background="@android:color/darker_gray" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/activity_margin"
            android:text="@string/test_the_openpgp_card" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="@dimen/activity_margin">

            <Button
                android:id="@+id/btn_test_action"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/openpgp_btn_read" />

            <ProgressBar
                android:id="@+id/progress_read"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical|end"
                android:layout_marginEnd="16dp"
                android:visibility="gone" />

        </FrameLayout>

        <TextView
            android:id="@+id/read_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_horizontal"
            android:textSize="12sp"
            android:textColor="@android:color/darker_gray"
            android:fontFamily="monospace"
            android:text=""
            tools:text="Reading slot SIG…" />

        <View
            android:layout_width="match_parent"
            android:layout_height="5dp"
            android:layout_marginVertical="@dimen/activity_margin"
            android:background="@android:color/darker_gray" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/activity_margin"
            android:text="@string/wipe_the_openpgp_key" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/activity_margin">

            <Button
                android:id="@+id/btn_delete_openpgp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/openpgp_btn_reset"
                android:backgroundTint="#B71C1C" />

            <ProgressBar
                android:id="@+id/progress_wipe"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical|end"
                android:layout_marginEnd="16dp"
                android:visibility="gone" />

        </FrameLayout>

        <TextView
            android:id="@+id/wipe_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_horizontal"
            android:textSize="12sp"
            android:textColor="@android:color/darker_gray"
            android:fontFamily="monospace"
            android:text=""
            tools:text="Blocking Admin PIN…" />

    </LinearLayout>
</ScrollView>